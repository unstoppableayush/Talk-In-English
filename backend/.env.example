# Backend environment variables (copy to .env)
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://speaking_app:localdev@localhost:5432/speaking_app
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-this-to-a-random-secret-in-production
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
DEEPGRAM_API_KEY=your-deepgram-key-here
GROQ_API_KEY=gsk-your-groq-key-here
ELEVENLABS_API_KEY=sk-your-elevenlabs-key-here
TTS_PROVIDER_ORDER=elevenlabs,deepgram,openai
DEEPGRAM_TTS_MODEL=aura-asteria-en
STT_PROVIDER_ORDER=deepgram,groq,elevenlabs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_TOKEN_CLOCK_SKEW_SECONDS=10
