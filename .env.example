# ========================
# Speaking App — Environment Variables
# ========================

# Database
POSTGRES_PASSWORD=change-this-to-a-strong-password

# Auth
JWT_SECRET=change-this-to-a-random-256-bit-key

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AI Keys — at least one LLM key is required; others are optional fallbacks
OPENAI_API_KEY=sk-...
GROK_API_KEY=xai-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=sk-...

# LLM provider priority (first available key wins, auto-fallback on failure)
LLM_PROVIDER_ORDER=openai,grok,gemini,deepseek

# TTS Keys — ElevenLabs preferred; OpenAI TTS as fallback
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
TTS_PROVIDER_ORDER=elevenlabs,openai

# Speech-to-Text
DEEPGRAM_API_KEY=...

# CORS (comma-separated origins)
CORS_ORIGINS=https://yourdomain.com

# Backend
BACKEND_REPLICAS=2
LOG_LEVEL=info
ENVIRONMENT=production

# Ports
HTTP_PORT=80
HTTPS_PORT=443
